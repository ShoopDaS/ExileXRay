.yarn/install-state.gz

# Build output
dist/
build/Release/
out/
*.tsbuildinfo

# Electron / electron-builder packaging artifacts
release/
*.AppImage
*.deb
*.rpm
*.snap
*.dmg
*.exe
*.blockmap
# electron-updater publish metadata (generated at build time)
latest-linux.yml
latest-mac.yml
latest.yml

# Native addon build artifacts (prebuilds are pulled at install/rebuild time)
*.node
prebuilds/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
crash.log

# Test / coverage
coverage/
.vitest/
.nyc_output/

# Caches
.cache/
.vite/
.eslintcache

# Local env / secrets
.env
.env.*
!.env.example

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# Local runtime data (userData lives in ~/.config; never commit captures/dumps)
*.local
/tmp-capture/
debug-crop*.png

# NOTE: the following are intentionally NOT ignored — they are vendored/committed:
#   resources/cv-ocr/**     (Tesseract + OpenCV WASM, eng.traineddata)
#   renderer/public/**      (bundled icons)
#   test fixture PNGs of real panels (OCR regression tests)
